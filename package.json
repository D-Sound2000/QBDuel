{
  "name": "qb-duel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:ws": "tsx watch src/server/index.ts",
    "dev:all": "concurrently -n web,ws -c cyan,magenta \"npm run dev\" \"npm run dev:ws\"",
    "start": "next start",
    "start:ws": "tsx src/server/index.ts",
    "build": "next build --webpack",
